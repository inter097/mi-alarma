    <!-- Pantalla de permisos y batería -->
    <string name="permissions_title">Permisos y batería</string>
    <string name="permissions_intro">Para que tus alarmas suenen siempre a tiempo, incluso con la pantalla bloqueada o el modo de ahorro de energía activado, revisa estos ajustes:</string>

    <string name="perm_exact_alarm_title">Alarmas y recordatorios exactos</string>
    <string name="perm_exact_alarm_description">Permite que la app programe alarmas exactas que suenen incluso en modo de ahorro de energía (Doze).</string>
    <string name="perm_exact_alarm_granted">Permiso concedido</string>
    <string name="perm_exact_alarm_not_granted">Permiso no concedido</string>
    <string name="perm_open_settings">Abrir ajustes</string>

    <string name="perm_notifications_title">Notificaciones</string>
    <string name="perm_notifications_description">Necesarias para mostrar el aviso de alarma sonando y los botones de posponer/descartar.</string>
    <string name="perm_notifications_granted">Permiso concedido</string>
    <string name="perm_notifications_not_granted">Permiso no concedido</string>
    <string name="perm_request">Conceder permiso</string>

    <string name="perm_full_screen_title">Mostrar sobre pantalla de bloqueo</string>
    <string name="perm_full_screen_description">Permite que la pantalla de alarma aparezca a pantalla completa aunque el teléfono esté bloqueado.</string>
    <string name="perm_full_screen_granted">Permiso concedido</string>
    <string name="perm_full_screen_not_granted">Permiso no concedido</string>

    <string name="battery_section_title">Optimización de batería</string>
    <string name="battery_section_description">Android puede cerrar la app en segundo plano para ahorrar batería, lo que podría impedir que tu alarma suene. Desactiva la optimización de batería para Mi Alarma.</string>
    <string name="battery_optimized">Optimización activada (recomendado desactivar)</string>
    <string name="battery_not_optimized">Optimización desactivada</string>
    <string name="battery_open_settings">Desactivar optimización de batería</string>

    <string name="autostart_section_title">Inicio automático (Xiaomi / HyperOS y otros fabricantes)</string>
    <string name="autostart_section_description">En dispositivos Xiaomi, Redmi, POCO (HyperOS/MIUI) y de otros fabricantes como Huawei, Oppo o Samsung, debes activar manualmente el \"Inicio automático\" (Autostart) de Mi Alarma para que pueda sonar tras reiniciar el teléfono o con la app cerrada.</string>
    <string name="autostart_steps_title">Pasos sugeridos:</string>
    <string name="autostart_step_1">1. Abre Ajustes ➝ Aplicaciones ➝ Permisos ➝ Inicio automático.</string>
    <string name="autostart_step_2">2. Busca \"Mi Alarma\" y activa el interruptor.</string>
    <string name="autostart_step_3">3. También revisa Ajustes ➝ Batería ➝ Uso de batería de la app y elige \"Sin restricciones\".</string>
    <string name="autostart_open_settings">Abrir ajustes de inicio automático</string>
    <string name="autostart_not_available">No se encontró un acceso directo para este fabricante. Busca \"Inicio automático\" en los ajustes del sistema.</string>
</resources>
